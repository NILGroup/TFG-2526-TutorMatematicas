{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jorge-informatica.example/schemas/student_preferences.schema.json",
  "title": "StudentPreferences",
  "type": "object",
  "additionalProperties": false,
  "required": ["student_id", "academic_profile", "goals", "preferences", "created_at", "updated_at", "schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for backwards-compatible migrations."
    },

    "student_id": {
      "type": "string",
      "description": "Unique student identifier (e.g., MongoDB ObjectId as string or UUID)."
    },

    "academic_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["course_level"],
      "properties": {
        "course_level": {
          "type": "string",
          "description": "Student course aligned with ESO/Bachillerato taxonomy.",
          "enum": ["1ESO", "2ESO", "3ESO", "4ESO", "1BACH", "2BACH"]
        },
        "track": {
          "type": ["string", "null"],
          "description": "Optional track, varies by course/community.",
          "enum": ["ACADEMIC_APPLIED", "SCI_TECH", "SOCIAL_SCI", "GENERAL", null]
        }
      }
    },

    "goals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_goal", "exam_prep"],
      "properties": {
        "primary_goal": {
          "type": "string",
          "enum": ["IMPROVE_GRADES", "EXAM_PREP", "REVIEW", "LEARN_AHEAD", "GENERAL_PRACTICE"]
        },
        "exam_prep": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "exam_date": {
              "type": ["string", "null"],
              "format": "date",
              "description": "If enabled=true, optionally store next exam date.",
              "default": null
            }
          }
        }
      }
    },

    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interest",
        "difficulty",
        "formats",
        "learning_support",
        "session",
        "recommendation_policy",
        "motivation"
      ],
      "properties": {
        "interest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kc_interest", "topic_like", "topic_dislike"],
          "properties": {
            "kc_interest": {
              "type": "object",
              "description": "Per-KC interest weights. Keys must match your taxonomy KC identifiers.",
              "additionalProperties": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "default": {}
            },
            "topic_like": {
              "type": "array",
              "description": "High-level topic likes for UX and cold-start heuristics.",
              "items": {
                "type": "string",
                "enum": [
                  "ALGEBRA",
                  "GEOMETRY",
                  "FUNCTIONS_GRAPHS",
                  "TRIGONOMETRY",
                  "CALCULUS",
                  "PROBABILITY_STATISTICS",
                  "LOGIC_REASONING",
                  "WORD_PROBLEMS"
                ]
              },
              "uniqueItems": true,
              "default": []
            },
            "topic_dislike": {
              "type": "array",
              "description": "High-level topic dislikes; should not hard-block content, just downweight.",
              "items": {
                "type": "string",
                "enum": [
                  "ALGEBRA",
                  "GEOMETRY",
                  "FUNCTIONS_GRAPHS",
                  "TRIGONOMETRY",
                  "CALCULUS",
                  "PROBABILITY_STATISTICS",
                  "LOGIC_REASONING",
                  "WORD_PROBLEMS"
                ]
              },
              "uniqueItems": true,
              "default": []
            }
          }
        },

        "difficulty": {
          "type": "object",
          "additionalProperties": false,
          "required": ["challenge_preference", "repeat_tolerance", "stuck_strategy"],
          "properties": {
            "challenge_preference": {
              "type": "string",
              "enum": ["EASY_CONFIDENCE", "MEDIUM_THINKING", "HARD_CHALLENGE"]
            },
            "repeat_tolerance": {
              "type": "string",
              "enum": ["LIKES_REPETITION", "SOME_REPETITION_OK", "PREFERS_VARIETY"]
            },
            "stuck_strategy": {
              "type": "string",
              "description": "Preferred action when problems feel too hard.",
              "enum": ["HINT_AND_TRY", "SKIP_AND_RETURN", "SHOW_PARTIAL_SOLUTION"]
            }
          }
        },

        "formats": {
          "type": "object",
          "additionalProperties": false,
          "required": ["preferred_formats", "real_world_context", "concept_scope"],
          "properties": {
            "preferred_formats": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "SHORT_NUMERIC",
                  "STEP_BY_STEP_ALGEBRA",
                  "WORD_PROBLEM",
                  "GRAPH_INTERPRETATION",
                  "APPLIED_REAL_LIFE"
                ]
              },
              "uniqueItems": true,
              "default": []
            },
            "real_world_context": {
              "type": "string",
              "enum": ["YES", "SOMETIMES", "NO"]
            },
            "concept_scope": {
              "type": "string",
              "description": "Whether they prefer single-concept problems or mixed-concept problems.",
              "enum": ["SINGLE_CONCEPT", "MIXED_CONCEPT", "NO_PREFERENCE"]
            }
          }
        },

        "learning_support": {
          "type": "object",
          "additionalProperties": false,
          "required": ["help_preference", "explanation_depth", "socratic_style"],
          "properties": {
            "help_preference": {
              "type": "string",
              "description": "What type of help is most useful when stuck.",
              "enum": ["CONCEPT_EXPLANATION", "SMALL_HINT", "SIMILAR_EXAMPLE", "FULL_SOLUTION"]
            },
            "explanation_depth": {
              "type": "string",
              "enum": ["MINIMAL", "MODERATE", "DETAILED"]
            },
            "socratic_style": {
              "type": "string",
              "description": "Whether the tutor should ask check questions.",
              "enum": ["YES", "SOMETIMES", "NO"]
            }
          }
        },

        "session": {
          "type": "object",
          "additionalProperties": false,
          "required": ["session_length", "problems_per_session", "cadence"],
          "properties": {
            "session_length": {
              "type": "string",
              "enum": ["LT_10_MIN", "MIN_10_20", "MIN_20_40", "GT_40_MIN"]
            },
            "problems_per_session": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30,
              "description": "Preferred number of problems in a typical session."
            },
            "cadence": {
              "type": "string",
              "description": "Short daily sessions vs fewer longer sessions.",
              "enum": ["SHORT_DAILY", "FEWER_LONGER", "NO_PREFERENCE"]
            }
          }
        },

        "recommendation_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["focus_mode", "exploration_ratio"],
          "properties": {
            "focus_mode": {
              "type": "string",
              "description": "How recommendations should trade off weaknesses vs interests.",
              "enum": ["FOCUS_WEAKNESSES", "BALANCED", "FOCUS_INTERESTS"]
            },
            "exploration_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Fraction of recommended items that can be exploratory/novel (cold-start friendly).",
              "default": 0.2
            }
          }
        },

        "motivation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["motivator", "mistake_response"],
          "properties": {
            "motivator": {
              "type": "string",
              "enum": ["PROGRESS_MASTERY", "DIFFICULT_PROBLEMS", "DAILY_GOALS", "DEEP_UNDERSTANDING"]
            },
            "mistake_response": {
              "type": "string",
              "description": "Affective preference; use for UX tone and pacing, not mastery.",
              "enum": ["MOTIVATED", "NEUTRAL", "FRUSTRATED"]
            }
          }
        }
      }
    },

    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
