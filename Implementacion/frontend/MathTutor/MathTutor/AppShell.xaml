<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MathTutor.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.SegmentedControl;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pages="clr-namespace:MathTutor.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="MathTutor">

    <!-- ── Tab bar (main navigation) ── -->
    <TabBar>
        <ShellContent Title="Hoy" Icon="calendar.png"
                      ContentTemplate="{DataTemplate pages:MainPage}" />
        <ShellContent Title="Biblioteca" Icon="library.png"
                      ContentTemplate="{DataTemplate pages:ProblemsLibraryPage}" />
        <ShellContent Title="Perfil" Icon="profile.png"
                      ContentTemplate="{DataTemplate pages:ProfilePage}" />
        <ShellContent Title="Ajustes" Icon="settings.png"
                      ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>

