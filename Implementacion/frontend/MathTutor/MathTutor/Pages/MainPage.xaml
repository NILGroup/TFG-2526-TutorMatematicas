<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:MathTutor.PageModels"
             xmlns:models="clr-namespace:MathTutor.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MathTutor.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             x:Name="OverviewPage"
             Title="Hoy">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertBool" />
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="IsNotNullOrEmpty" />
    </ContentPage.Resources>

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing"
                                        Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid>
        <!--
            Same proven pattern as the Library page: CollectionView with
            SelectionChanged handled in code-behind. The static page chrome
            (title, generate button, error banner, empty state) lives in
            CollectionView.Header so it scrolls with the list and there is
            no nested-scroll or hit-test conflict.
        -->
        <CollectionView x:Name="ProblemsCollectionView"
                        ItemsSource="{Binding RecommendedProblems}"
                        SelectionMode="Single"
                        SelectionChanged="OnProblemSelected">

            <CollectionView.Header>
                <VerticalStackLayout Padding="{StaticResource LayoutPadding}"
                                     Spacing="{StaticResource LayoutSpacing}">

                    <Label Text="Recomendaciones de hoy"
                           Style="{StaticResource Title1}" />

                    <Label Text="Genera una sesión personalizada basada en tus intereses y progreso."
                           Style="{StaticResource Body2}"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                    <Button Text="Generar sesión"
                            Command="{Binding GenerateSessionCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            HorizontalOptions="Fill"
                            Margin="0,4,0,0" />

                    <Border IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmpty}}"
                            BackgroundColor="#FEE2E2"
                            Stroke="#DC2626"
                            StrokeThickness="1"
                            Padding="12,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#991B1B"
                               Style="{StaticResource Caption1}" />
                    </Border>

                    <VerticalStackLayout IsVisible="{Binding ShowEmptyState}"
                                         HorizontalOptions="Center"
                                         Padding="20,32"
                                         Spacing="10">
                        <Label Text="🎯"
                               FontSize="40"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Sin sesión activa"
                               Style="{StaticResource Title3}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Pulsa «Generar sesión» para recibir problemas adaptados a tu nivel."
                               Style="{StaticResource Body2}"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    </VerticalStackLayout>

                    <Label IsVisible="{Binding HasSession}"
                           Text="Selecciona un problema para empezar:"
                           Style="{StaticResource Body2Strong}"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ProblemOut">
                    <Border Style="{StaticResource CardStyle}"
                            Margin="{OnIdiom '12,4', Desktop='16,6'}">

                        <VerticalStackLayout Spacing="10">

                            <HorizontalStackLayout Spacing="8">
                                <Border BackgroundColor="{StaticResource Primary}"
                                        StrokeThickness="0" Padding="8,3">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label TextColor="White"
                                           Style="{StaticResource Caption1Strong}">
                                        <Label.Text>
                                            <Binding Path="Course"
                                                     TargetNullValue="Curso ?" />
                                        </Label.Text>
                                    </Label>
                                </Border>

                                <Border BackgroundColor="{AppThemeBinding
                                            Light={StaticResource LightSecondaryBackground},
                                            Dark={StaticResource DarkSecondaryBackground}}"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource Primary}"
                                        Padding="8,3">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label TextColor="{StaticResource Primary}"
                                           Style="{StaticResource Caption1Strong}">
                                        <Label.Text>
                                            <Binding Path="Difficulty"
                                                     StringFormat="Dif. {0}/5"
                                                     TargetNullValue="—" />
                                        </Label.Text>
                                    </Label>
                                </Border>
                            </HorizontalStackLayout>

                            <Label Text="{Binding RenderedStatement}"
                                   Style="{StaticResource Body1}"
                                   MaxLines="3"
                                   LineBreakMode="TailTruncation" />

                            <Label Style="{StaticResource Caption1}"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource Gray500},
                                       Dark={StaticResource Gray400}}">
                                <Label.Text>
                                    <Binding Path="Kc"
                                             StringFormat="Área: {0}"
                                             TargetNullValue="" />
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="24" Color="Transparent" />
            </CollectionView.Footer>
        </CollectionView>

        <Border IsVisible="{Binding IsBusy}"
                BackgroundColor="#AA000000"
                StrokeThickness="0">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="White"
                                   HeightRequest="48" WidthRequest="48" />
                <Label Text="Generando sesión…"
                       TextColor="White"
                       Style="{StaticResource Body2}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
